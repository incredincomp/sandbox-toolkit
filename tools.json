{
  "$schema": "./schemas/tools.schema.json",
  "schema_version": "1.0",
  "tools": [
    {
      "id": "7zip",
      "display_name": "7-Zip",
      "category": "utility",
      "profiles": ["minimal", "reverse-engineering", "network-analysis", "full"],
      "source_type": "vendor",
      "source_url": "https://www.7-zip.org/a/7z2409-x64.msi",
      "version": "24.09",
      "filename": "7zip.msi",
      "installer_type": "msi",
      "install_args": "/qn /norestart",
      "install_order": 1,
      "notes": "Must install first; used to extract all zip-based tools."
    },
    {
      "id": "vscode",
      "display_name": "Visual Studio Code",
      "category": "editor",
      "profiles": ["minimal", "reverse-engineering", "network-analysis", "full"],
      "source_type": "vendor",
      "source_url": "https://update.code.visualstudio.com/latest/win32-x64-user/stable",
      "version": "latest",
      "filename": "vscode.exe",
      "installer_type": "exe",
      "install_args": "/verysilent /suppressmsgboxes /MERGETASKS=!runcode,desktopicon,addcontextmenufiles,addcontextmenufolders,addtopath",
      "install_order": 2,
      "notes": "URL always resolves to current stable release."
    },
    {
      "id": "notepadpp",
      "display_name": "Notepad++",
      "category": "editor",
      "profiles": ["minimal", "reverse-engineering", "network-analysis", "full"],
      "source_type": "github_release",
      "github_repo": "notepad-plus-plus/notepad-plus-plus",
      "asset_pattern": "npp.*.Installer.x64.exe",
      "version": "latest",
      "filename": "notepadpp.exe",
      "installer_type": "exe",
      "install_args": "/S",
      "install_order": 3
    },
    {
      "id": "python3",
      "display_name": "Python 3",
      "category": "runtime",
      "profiles": ["minimal", "reverse-engineering", "network-analysis", "full"],
      "source_type": "vendor",
      "source_url": "https://www.python.org/ftp/python/3.13.2/python-3.13.2-amd64.exe",
      "version": "3.13.2",
      "filename": "python3.exe",
      "installer_type": "exe",
      "install_args": "/quiet InstallAllUsers=1 PrependPath=1",
      "install_order": 4,
      "notes": "Pin updated from EOL 3.9.1. Python 2 removed (EOL Jan 2020)."
    },
    {
      "id": "corretto21",
      "display_name": "Amazon Corretto JDK 21",
      "category": "runtime",
      "profiles": ["reverse-engineering", "network-analysis", "full"],
      "source_type": "vendor",
      "source_url": "https://corretto.aws/downloads/latest/amazon-corretto-21-x64-windows-jdk.msi",
      "version": "latest",
      "filename": "corretto21.msi",
      "installer_type": "msi",
      "install_args": "/qn /norestart",
      "install_order": 5,
      "notes": "Ghidra 11.x requires JDK 21+. Updated from Corretto 11."
    },
    {
      "id": "vcredist",
      "display_name": "Visual C++ Redistributable x64",
      "category": "runtime",
      "profiles": ["reverse-engineering", "network-analysis", "full"],
      "source_type": "vendor",
      "source_url": "https://aka.ms/vs/17/release/vc_redist.x64.exe",
      "version": "latest",
      "filename": "vcredist_x64.exe",
      "installer_type": "exe",
      "install_args": "/passive /norestart",
      "install_order": 6,
      "notes": "Required by PE-bear and other native tools."
    },
    {
      "id": "sysinternals",
      "display_name": "Sysinternals Suite",
      "category": "sysanalysis",
      "profiles": ["minimal", "reverse-engineering", "network-analysis", "full"],
      "source_type": "vendor",
      "source_url": "https://download.sysinternals.com/files/SysinternalsSuite.zip",
      "version": "latest",
      "filename": "sysinternals.zip",
      "installer_type": "zip",
      "extract_dest": "%USERPROFILE%\\Desktop\\Sysinternals",
      "install_order": 10,
      "notes": "Portable. Extracted to Desktop."
    },
    {
      "id": "ghidra",
      "display_name": "Ghidra",
      "category": "reversing",
      "profiles": ["reverse-engineering", "network-analysis", "full"],
      "source_type": "github_release",
      "github_repo": "NationalSecurityAgency/ghidra",
      "asset_pattern": "ghidra_*_PUBLIC_*.zip",
      "version": "latest",
      "filename": "ghidra.zip",
      "installer_type": "zip",
      "extract_dest": "%USERPROFILE%\\Desktop\\Ghidra",
      "install_order": 20,
      "dependencies": ["corretto21"],
      "notes": "Requires JDK 21 (Corretto 21). Launch ghidraRun.bat from extracted folder."
    },
    {
      "id": "x64dbg",
      "display_name": "x64dbg",
      "category": "reversing",
      "profiles": ["reverse-engineering", "network-analysis", "full"],
      "source_type": "sourceforge",
      "source_url": "https://sourceforge.net/projects/x64dbg/files/latest/download",
      "version": "latest",
      "filename": "x64dbg.zip",
      "installer_type": "zip",
      "extract_dest": "%USERPROFILE%\\Desktop\\x64dbg",
      "install_order": 21,
      "notes": "Snapshot builds are the only official distribution. Portable."
    },
    {
      "id": "dnspyex",
      "display_name": "dnSpyEx",
      "category": "reversing",
      "profiles": ["reverse-engineering", "network-analysis", "full"],
      "source_type": "github_release",
      "github_repo": "dnSpyEx/dnSpy",
      "asset_pattern": "dnSpy-net-win64.zip",
      "version": "latest",
      "filename": "dnspyex.zip",
      "installer_type": "zip",
      "extract_dest": "%USERPROFILE%\\Desktop\\dnSpyEx",
      "install_order": 22,
      "notes": "Active maintained fork of the archived dnSpy project. .NET decompiler/debugger."
    },
    {
      "id": "detectiteasy",
      "display_name": "Detect-It-Easy",
      "category": "reversing",
      "profiles": ["reverse-engineering", "network-analysis", "full"],
      "source_type": "github_release",
      "github_repo": "horsicq/DIE-engine",
      "asset_pattern": "die_win64_portable_*.zip",
      "version": "latest",
      "filename": "detectiteasy.zip",
      "installer_type": "zip",
      "extract_dest": "%USERPROFILE%\\Desktop\\DetectItEasy",
      "install_order": 23,
      "notes": "Packer/compiler/protector identifier."
    },
    {
      "id": "upx",
      "display_name": "UPX",
      "category": "reversing",
      "profiles": ["reverse-engineering", "network-analysis", "full"],
      "source_type": "github_release",
      "github_repo": "upx/upx",
      "asset_pattern": "upx-*-win64.zip",
      "version": "latest",
      "filename": "upx.zip",
      "installer_type": "zip",
      "extract_dest": "%USERPROFILE%\\Desktop\\upx",
      "install_order": 24,
      "notes": "UPX packer/unpacker. Portable."
    },
    {
      "id": "pebear",
      "display_name": "PE-bear",
      "category": "reversing",
      "profiles": ["reverse-engineering", "network-analysis", "full"],
      "source_type": "github_release",
      "github_repo": "hasherezade/pe-bear",
      "asset_pattern": "PE-bear_*_x64_win_*.zip",
      "version": "latest",
      "filename": "pebear.zip",
      "installer_type": "zip",
      "extract_dest": "%USERPROFILE%\\Desktop\\PE-bear",
      "install_order": 25,
      "dependencies": ["vcredist"],
      "notes": "PE file viewer/editor. Requires VC++ redistributable."
    },
    {
      "id": "pestudio",
      "display_name": "pestudio",
      "category": "reversing",
      "profiles": ["reverse-engineering", "network-analysis", "full"],
      "source_type": "vendor",
      "source_url": "https://www.winitor.com/tools/pestudio/current/pestudio.zip",
      "version": "latest",
      "filename": "pestudio.zip",
      "installer_type": "zip",
      "extract_dest": "%USERPROFILE%\\Desktop\\pestudio",
      "install_order": 26,
      "notes": "PE static analysis. Portable."
    },
    {
      "id": "hxd",
      "display_name": "HxD Hex Editor",
      "category": "reversing",
      "profiles": ["reverse-engineering", "network-analysis", "full"],
      "source_type": "vendor",
      "source_url": "https://mh-nexus.de/downloads/HxDSetup.zip",
      "version": "latest",
      "filename": "hxd.zip",
      "installer_type": "zip_then_exe",
      "inner_exe": "HxDSetup.exe",
      "inner_args": "/VERYSILENT /NORESTART",
      "install_order": 27,
      "notes": "Distributed as a zip containing an installer."
    },
    {
      "id": "floss",
      "display_name": "FLARE FLOSS",
      "category": "reversing",
      "profiles": ["reverse-engineering", "network-analysis", "full"],
      "source_type": "github_release",
      "github_repo": "mandiant/flare-floss",
      "asset_pattern": "floss-v*-windows.zip",
      "version": "latest",
      "filename": "floss.zip",
      "installer_type": "zip",
      "extract_dest": "%USERPROFILE%\\Desktop\\floss",
      "install_order": 28,
      "notes": "MANDIANT/FLARE obfuscated string solver. Extracts obfuscated strings from malware binaries."
    },
    {
      "id": "wireshark",
      "display_name": "Wireshark",
      "category": "network",
      "profiles": ["network-analysis", "full"],
      "source_type": "vendor",
      "source_url": "https://2.na.dl.wireshark.org/win64/Wireshark-4.4.6-x64.exe",
      "version": "4.4.6",
      "filename": "wireshark.exe",
      "installer_type": "exe",
      "install_args": "/S /desktopicon=yes",
      "install_order": 30,
      "notes": "Network-analysis and full profiles only. Sandbox networking must be enabled."
    },
    {
      "id": "npcap",
      "display_name": "Npcap",
      "category": "network",
      "profiles": ["network-analysis", "full"],
      "source_type": "vendor",
      "source_url": "https://npcap.com/dist/npcap-1.82.exe",
      "version": "1.82",
      "filename": "npcap.exe",
      "installer_type": "manual",
      "install_order": 31,
      "notes": "MANUAL INSTALL REQUIRED: Npcap does not support silent install. Run manually after sandbox starts. Required for Wireshark live capture."
    }
  ],
  "removed_tools": [
    {
      "id": "python2",
      "reason": "Python 2 reached end-of-life in January 2020. Removed to reduce attack surface."
    },
    {
      "id": "dosbox",
      "reason": "Not relevant to malware analysis or reverse engineering workflows."
    },
    {
      "id": "sublime_text",
      "reason": "Redundant with VSCode and Notepad++. Removed to reduce install size."
    },
    {
      "id": "autoit_extractor",
      "reason": "Sourced from an unverified GitLab CI artifact with no stable release. Cannot reliably verify integrity."
    },
    {
      "id": "dnspy_original",
      "reason": "Archived by original author 0xd4d in 2022. Replaced by the maintained dnSpyEx fork."
    }
  ]
}
